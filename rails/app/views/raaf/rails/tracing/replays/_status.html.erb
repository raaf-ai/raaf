<%# Turbo Stream status partial for SpanReplay updates %>
<div id="replay-status" class="mt-4">
  <% if replay.pending? %>
    <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
      <div class="flex items-center">
        <div class="animate-pulse mr-3">
          <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <span class="font-medium text-gray-700">Pending</span>
          <span class="ml-2 text-sm text-gray-500">Replay queued for execution...</span>
        </div>
      </div>
    </div>

  <% elsif replay.running? %>
    <div class="bg-blue-50 border border-blue-200 rounded-xl p-4">
      <div class="flex items-center">
        <div class="animate-spin mr-3">
          <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
        </div>
        <div>
          <span class="font-medium text-blue-800">Running</span>
          <span class="ml-2 text-sm text-blue-600">Executing replay with modified configuration...</span>
        </div>
      </div>
    </div>

  <% elsif replay.completed? %>
    <div class="bg-green-50 border border-green-200 rounded-xl p-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <svg class="w-5 h-5 text-green-600 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <span class="font-medium text-green-800">Completed</span>
            <span class="ml-2 text-sm text-green-600">Replay executed successfully</span>
          </div>
        </div>
        <% if replay.replayed_span.present? %>
          <%= link_to "View Result",
                      "/raaf/tracing/spans/#{replay.replayed_span.span_id}",
                      class: "inline-flex items-center px-3 py-1.5 text-sm font-medium text-green-700 bg-green-100 rounded-lg hover:bg-green-200 transition-colors" %>
        <% end %>
      </div>
    </div>

  <% elsif replay.failed? %>
    <div class="bg-red-50 border border-red-200 rounded-xl p-4">
      <div class="flex items-start">
        <svg class="w-5 h-5 text-red-600 mr-3 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div class="flex-1">
          <span class="font-medium text-red-800">Failed</span>
          <% if replay.error_message.present? %>
            <p class="mt-1 text-sm text-red-600"><%= replay.error_message %></p>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
